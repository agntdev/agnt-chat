[
  {
    "name": "/clear resets conversation history",
    "steps": [
      {
        "send": { "text": "/clear" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Chat history cleared! 🗑\n\nSend me a message to start fresh." }
          }
        ]
      }
    ]
  },
  {
    "name": "the Clear menu button confirms and clears",
    "steps": [
      {
        "send": { "callback": "clear:confirm" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]
